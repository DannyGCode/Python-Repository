        self.tree_filter.pack(fill=tk.BOTH, expand=True)

        # Visualize
        self.tab_viz = ttk.Frame(self.nb, padding=10)
        self.nb.add(self.tab_viz, text="Visualize")

        vbar = ttk.Frame(self.tab_viz)
        vbar.pack(fill=tk.X)
        ttk.Button(
            vbar, text="Top Firmware Versions", command=self._viz_top_fw
        ).pack(side=tk.LEFT, padx=4)
        ttk.Button(vbar, text="Devices by Model", command=self._viz_by_model).pack(
            side=tk.LEFT, padx=4
        )
        ttk.Button(
            vbar, text="Outdated by Model", command=self._viz_outdated_by_model
        ).pack(side=tk.LEFT, padx=4)
        ttk.Button(vbar, text="Save Chart as PNG", command=save_current_figure).pack(
            side=tk.LEFT, padx=12
        )

        self.fig = plt.Figure(figsize=(7.5, 4.5))
        self.ax = self.fig.add_subplot(111)
        self.canvas = FigureCanvasTkAgg(self.fig, master=self.tab_viz)
        self.canvas.get_tk_widget().pack(fill=tk.BOTH, expand=True, pady=8)

        # initialize empties
        for tree in (
            self.tree_dash,
            self.tree_marsha,
            self.tree_fwcount,
            self.tree_filter,
        ):
            tree["columns"] = []
            tree["show"] = "headings"

        self.nb.bind("<<NotebookTabChanged>>", lambda e: self._on_search())

    def _make_statusbar(self):
        self.status = ttk.Label(
            self.root, text="Ready.", anchor="w", style="Small.TLabel"
        )
        self.status.pack(side=tk.BOTTOM, fill=tk.X, padx=8, pady=2)

    def _bind_context_menus(self):
        self._ctx_menu = tk.Menu(self.root, tearoff=0)
        self._ctx_menu.add_command(
            label="Copy selected row(s)", command=self._ctx_copy_rows
        )
        self._ctx_menu.add_command(
            label="Copy table (CSV)", command=self._ctx_copy_table
        )
        for tree in (
            self.tree_dash,
            self.tree_marsha,
            self.tree_fwcount,
            self.tree_filter,
        ):
            tree.bind("<Button-3>", lambda e, t=tree: self._show_ctx_menu(e, t))

    def _show_ctx_menu(self, event, tree):
        self._ctx_target = tree
        try:
            self._ctx_menu.tk_popup(event.x_root, event.y_root)
        finally:
            self._ctx_menu.grab_release()

    def _ctx_copy_rows(self):
        t = getattr(self, "_ctx_target", None)
        if not t:
            return
        cols = t["columns"]
        rows = []
        for iid in t.selection():
            rows.append(t.item(iid)["values"])
        if not rows:
            messagebox.showinfo("Copy", "No rows selected.")
            return
        df = pd.DataFrame(rows, columns=cols)
        copy_tree_to_clipboard(self.root, df)

    def _ctx_copy_table(self):
        tree, df = self._current_tree_and_df()
        if df is None or df.empty:
            messagebox.showwarning("Copy", "No data on this tab.")
            return
        copy_tree_to_clipboard(self.root, df)

    # ---------- Data I/O ----------
    def load_file(self):
        file_path = filedialog.askopenfilename(
            filetypes=[
                ("Data files", "*.xlsx *.xls *.csv *.txt *.log"),
                ("All files", "*.*"),
            ]
        )
        if not file_path:
            return
        try:
            df = self._read_any(file_path)
            self._ingest_dataframe(df, f"Loaded file: {file_path}")
        except Exception as e:
            messagebox.showerror("File Load Error", str(e))

    def paste_clipboard(self):
        try:
            text = self.root.clipboard_get()
        except Exception:
            messagebox.showerror("Clipboard", "No text in clipboard.")
            return
        try:
            try:
                dialect = csv.Sniffer().sniff(text.splitlines()[0] if text else ",")
                delim = dialect.delimiter
            except Exception:
                delim = "\t" if "\t" in text else ","
            from io import StringIO

            df = pd.read_csv(StringIO(text), sep=delim, engine="python")
            self._ingest_dataframe(df, "Pasted from clipboard")
        except Exception as e:
            messagebox.showerror("Clipboard Parse Error", str(e))

    def _read_any(self, file_path: str) -> pd.DataFrame:
        low = file_path.lower()
        if low.endswith((".xlsx", ".xls")):
            return pd.read_excel(file_path)
        with open(file_path, "r", encoding="utf-8", errors="ignore") as f:
            first = f.readline()
        if first.lower().startswith("sep="):
            sep = first.strip().split("=", 1)[1] or ","
            return pd.read_csv(
                file_path,
                sep=sep,
                skiprows=1,
                engine="python",
                on_bad_lines="skip",
            )
        with open(file_path, "r", encoding="utf-8", errors="ignore") as f:
            sample = f.read(4096)
        try:
            dialect = csv.Sniffer().sniff(sample)
            sep = dialect.delimiter
        except Exception:
            sep = "," if "," in sample else "\t"
        return pd.read_csv(file_path, sep=sep, engine="python", on_bad_lines="skip")

    def _ingest_dataframe(self, df: pd.DataFrame, status_msg: str):
        df = normalize_columns(df)
        err = require_columns(df)
        if err:
            messagebox.showerror("Missing Columns", err)
            return
        self.state.raw = df.copy()
        self.state.clean = clean_and_enrich(df.copy())

        sites = ["All"] + sorted(
            self.state.clean["Marsha Code"].dropna().unique().tolist()
        )
        self.site_combo["values"] = sites
        self.site_combo.set("All")

        self.update_all_tables()
        self._toast(status_msg)

    # ---------- Tables & KPIs ----------
    def update_all_tables(self):
        if self.state.clean is None:
            return
        clean = self.state.clean
        key_col = _device_key_col(clean)
        analytic = _analytics_base(clean)

        # KPIs are all based on contact_num+realm, no SCA, no shadow IPs
        self.kpi_labels["records"].config(
            text=f"Phones Counted: {len(analytic):,}"
        )
        self.kpi_labels["unique_users"].config(
            text=f"Unique Users: {analytic[key_col].nunique():,}"
        )
        self.kpi_labels["unique_realms"].config(
            text=f"Unique Realms: {analytic['digestrealm'].nunique():,}"
        )
        self.kpi_labels["device_models"].config(
            text=f"Device Models: {analytic['Device Type'].nunique():,}"
        )

        # Dashboard sample preview (from cleaned rows, not deduped)
        cols_dash = [
            "digestusername",
            "digestrealm",
            "contact_domain",
            "Device Type",
            "Firmware Version",
            "Marsha Code",
        ]
        sample = clean[cols_dash].head(200).copy()
        populate_tree_flat(self.tree_dash, sample)

        # Marsha & FW counts use analytics base internally
        self.state.marsha = marsha_count(clean)
        populate_tree_flat(self.tree_marsha, self.state.marsha)

        self.state.fwcount = firmware_count(clean)
        populate_tree_flat(self.tree_fwcount, self.state.fwcount)

        # FW filter starts with all non-shadow, deduped rows
        self.state.last_fw_filter_df = fw_filter(
            clean, version_prefix=None, latest_version=None
        )
        filter_tree(
            self.tree_filter,
            self.state.last_fw_filter_df,
            self.filter_search_var.get(),
            grouped=self.group_sites_var.get(),
            site_filter=self.site_var.get(),
        )

        # Default viz
        self._viz_top_fw()

    def _apply_filter(self):
        if self.state.clean is None:
            return
        latest = self.latest_var.get().strip() or None
        prefix = self.prefix_var.get().strip() or None
        out = fw_filter(self.state.clean, prefix, latest)
        self.state.last_fw_filter_df = out
        filter_tree(
            self.tree_filter,
            out,
            self.filter_search_var.get(),
            grouped=self.group_sites_var.get(),
            site_filter=self.site_var.get(),
        )
        self._toast(f"Filter applied. Rows: {len(out):,}")

    # ---------- Search & Export ----------
    def _current_tree_and_df(self):
        tab = self.nb.tab(self.nb.select(), "text")
        if tab == "Dashboard":
            if self.state.clean is None:
                return self.tree_dash, pd.DataFrame()
            cols = [
                "digestusername",
                "digestrealm",
                "contact_domain",
                "Device Type",
                "Firmware Version",
                "Marsha Code",
            ]
            return self.tree_dash, self.state.clean[cols].head(200).copy()
        elif tab == "Marsha Count":
            return (
                self.tree_marsha,
                (self.state.marsha if self.state.marsha is not None else pd.DataFrame()),
            )
        elif tab == "Firmware Count":
            return (
                self.tree_fwcount,
                (self.state.fwcount if self.state.fwcount is not None else pd.DataFrame()),
            )
        elif tab == "FW Filter":
            df = (
                self.state.last_fw_filter_df
                if self.state.last_fw_filter_df is not None
                else pd.DataFrame()
            )
            if df is None or df.empty:
                return self.tree_filter, pd.DataFrame()
            q = self.filter_search_var.get()
            site = self.site_var.get()
            base = df
            if site and site != "All":
                base = base[base["Marsha Code"] == site]
            if q:
                ql = q.lower()
                mask = base.apply(
                    lambda s: s.astype(str).str.lower().str.contains(ql, na=False)
                )
                base = base[mask.any(axis=1)]
            return self.tree_filter, base.copy()
        elif tab == "Visualize":
            return None, None
        return None, None

    def _df_from_tree(self, tree: ttk.Treeview) -> pd.DataFrame:
        cols = tree["columns"]
        rows = []
        for iid in tree.get_children(""):
            rows.append(tree.item(iid)["values"])
        return pd.DataFrame(rows, columns=cols)

    def _on_search(self, event=None):
        tab = self.nb.tab(self.nb.select(), "text")
        if tab == "FW Filter" and self.state.last_fw_filter_df is not None:
            # Top global search does NOT feed into FW Filter;
            # FW Filter uses its own universal search bar.
            filter_tree(
                self.tree_filter,
                self.state.last_fw_filter_df,
                self.filter_search_var.get(),
                grouped=self.group_sites_var.get(),
                site_filter=self.site_var.get(),
            )
        else:
            tree, df = self._current_tree_and_df()
            if tree is None or df is None or df.empty:
                return
            # For non-FW Filter tabs, top search is global filter
            q = self.search_var.get()
            if not q or df.empty:
                populate_tree_flat(tree, df)
            else:
                ql = q.lower()
                mask = df.apply(
                    lambda s: s.astype(str).str.lower().str.contains(ql, na=False)
                )
                base = df[mask.any(axis=1)]
                populate_tree_flat(tree, base)

    def _on_filter_search(self, event=None):
        """
        Live-search handler for the FW Filter tab's universal search bar.
        This only affects the FW Filter tab and uses filter_search_var.
        """
        if self.state.last_fw_filter_df is None:
            return
        filter_tree(
            self.tree_filter,
            self.state.last_fw_filter_df,
            self.filter_search_var.get(),
            grouped=self.group_sites_var.get(),
            site_filter=self.site_var.get(),
        )

    def _export_current(self, to_excel: bool):
        tree, df = self._current_tree_and_df()
        if df is None or df.empty:
            messagebox.showwarning("Export", "No data to export on this tab.")
            return
        export_table(df, to_excel)

    # ---------- Visualization helpers ----------
    def _clear_ax(self):
        self.ax.clear()
        self.ax.set_xlabel("")
        self.ax.set_ylabel("")
        self.ax.set_title("")
        self.ax.yaxis.grid(True, linestyle="--", alpha=0.3)

    def _annotate_bars(self, values, total):
        """
        Annotate bar charts with "count (xx.x%)" labels.
        Assumes bars were just plotted on self.ax.
        """
        try:
            total_val = float(total)
        except (TypeError, ValueError):
            total_val = 0.0

        if total_val <= 0:
            return

        for rect, val in zip(self.ax.patches, values):
            try:
                v = float(val)
            except (TypeError, ValueError):
                continue
            pct = (v / total_val) * 100 if total_val else 0
            label = f"{int(v):,} ({pct:.1f}%)"
            height = rect.get_height()
            x = rect.get_x() + rect.get_width() / 2
            self.ax.annotate(
                label,
                (x, height),
                xytext=(0, 3),
                textcoords="offset points",
                ha="center",
                va="bottom",
                fontsize=8,
            )

    # ---------- Visualizations ----------
    def _viz_top_fw(self):
        if self.state.clean is None:
            return

        use = _analytics_base(self.state.clean)
        top = use.groupby("Firmware Version").size().sort_values(ascending=False).head(10)

        self._clear_ax()
        if top.empty:
            self.ax.text(
                0.5,
                0.5,
                "No data available.",
                ha="center",
                va="center",
                transform=self.ax.transAxes,
            )
        else:
            top.plot(kind="bar", ax=self.ax)
            self.ax.set_title("Top Firmware Versions (All Models)")
            self.ax.set_ylabel("Devices")

            for label in self.ax.get_xticklabels():
                label.set_rotation(35)
                label.set_ha("right")

            total = top.sum()
            self._annotate_bars(top.values, total)

        self.fig.tight_layout()
        self.canvas.draw()

    def _viz_by_model(self):
        if self.state.clean is None:
            return

        use = _analytics_base(self.state.clean)
        top = use.groupby("Device Type").size().sort_values(ascending=False).head(12)

        self._clear_ax()
        if top.empty:
            self.ax.text(
                0.5,
                0.5,
                "No data available.",
                ha="center",
                va="center",
                transform=self.ax.transAxes,
            )
        else:
            top.plot(kind="bar", ax=self.ax)
            self.ax.set_title("Devices by Model (Top 12)")
            self.ax.set_ylabel("Devices")

            for label in self.ax.get_xticklabels():
                label.set_rotation(35)
                label.set_ha("right")

            total = top.sum()
            self._annotate_bars(top.values, total)

        self.fig.tight_layout()
        self.canvas.draw()

    def _viz_outdated_by_model(self):
        if self.state.fwcount is None:
            self.update_all_tables()
            if self.state.fwcount is None:
                return

        fw = self.state.fwcount.copy()
        sub = fw[fw["Behind Latest?"] == True]  # noqa: E712

        self._clear_ax()
        if sub.empty:
            self.ax.text(
                0.5,
                0.5,
                "All devices are on latest firmware (or no data).",
                ha="center",
                va="center",
                transform=self.ax.transAxes,
            )
        else:
            agg = (
                sub.groupby("Device Type")["Device Count"]
                .sum()
                .sort_values(ascending=False)
                .head(12)
            )
            agg.plot(kind="bar", ax=self.ax)
            self.ax.set_title("Outdated Devices by Model (Top 12)")
            self.ax.set_ylabel("Outdated Devices")

            for label in self.ax.get_xticklabels():
                label.set_rotation(35)
                label.set_ha("right")

            total_outdated = agg.sum()
            self._annotate_bars(agg.values, total_outdated)

        self.fig.tight_layout()
        self.canvas.draw()

    # ---------- Toast/status ----------
    def _toast(self, msg: str):
        self.status.config(text=msg)
        self.root.after(3500, lambda: self.status.config(text="Ready."))

    # ---------- Main loop ----------
    def run(self):
        self.root.mainloop()


# ---------------- main ----------------
def main():
    app = FirmwareAnalyzerApp()
    app.run()


if __name__ == "__main__":
    main()
