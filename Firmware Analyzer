# Shadow / duplicate registration IPs
INVALID_IPS = {"192.168.60.200", "192.168.40.200", "192.168.20.200"}

# These must exist in the file, but we *no longer* drop other columns.
REQUIRED_COLS = ["digestusername", "digestrealm", "contact_domain", "ua"]

COLUMN_ALIASES = {
    "digest_user_name": "digestusername",
    "digest_user": "digestusername",
    "realm": "digestrealm",
    "contactdomain": "contact_domain",
    "domain": "contact_domain",
    "user_agent": "ua",
    "useragent": "ua",
    # Variants of contact number -> contact_num
    "contact-num": "contact_num",
    "contactnumber": "contact_num",
}

# Shared Call Appearance / mirrored registration pattern
# Examples: ASERA2289_m1, BNASH3110_J2, BNAWN1234_SCA1
SCA_SUFFIX_RE = re.compile(r".+_(?:[mM]\d+|[jJ]\d+|[sS][cC][aA]\d+)$")

# ---------------- Version helpers ----------------
def _digits_tuple(version_str: Optional[str], max_len: int = 6) -> Tuple[int, ...]:
    if not isinstance(version_str, str):
        return (0,)
    nums = re.findall(r"\d+", version_str)
    if not nums:
        return (0,)
    parts = tuple(int(n) for n in nums[:max_len])
    return parts or (0,)


def _pad_tuple(t: Tuple[int, ...], length: int) -> Tuple[int, ...]:
    if len(t) >= length:
        return t[:length]
    return t + (0,) * (length - len(t))


def parse_version(version: Optional[str]) -> Tuple[int, ...]:
    return _digits_tuple(version)


# ---------------- UA parsing ----------------
DEVICE_PATTERNS: List[Tuple[re.Pattern, Tuple[int, int]]] = [
    (re.compile(r"(Yealink.*?)\s+([0-9][\w.\-]+)$", re.I), (1, 2)),
    (re.compile(r"(Snom.*?)\s+([0-9][\w.\-]+)$", re.I), (1, 2)),
    (re.compile(r"(Poly(?:com)? .*?)\s+([0-9][\w.\-]+)$", re.I), (1, 2)),
    (re.compile(r"(VTech.*?)\s+([0-9][\w.\-]+)$", re.I), (1, 2)),
    (re.compile(r"(Grandstream.*?)\s+([0-9][\w.\-]+)$", re.I), (1, 2)),
    (re.compile(r"(.+?)[/ ]([0-9][\w.\-]+)\s*$", re.I), (1, 2)),  # generic
]


def extract_device_firmware(ua_value: Optional[str]) -> Tuple[str, str]:
    if isinstance(ua_value, str):
        ua = ua_value.strip()
        if ua:
            for pat, (dg, vg) in DEVICE_PATTERNS:
                m = pat.search(ua)
                if m:
                    device = re.sub(r"\s+", " ", m.group(dg)).strip()
                    ver = m.group(vg).strip()
                    return device, ver
    return "Unknown Device", "0.0.0"


# ---------------- Row selection ----------------
def prioritize_valid_ip(group: pd.DataFrame) -> pd.DataFrame:
    """
    For a given DeviceKey + realm group, prefer records whose contact_domain
    is NOT in INVALID_IPS (shadow / duplicate registration IPs).

    If all rows are on INVALID_IPS, we still keep one (so they can be inspected
    on the raw/preview tab), but analytics will later drop those IPs.
    """
    valid = group[~group["contact_domain"].isin(INVALID_IPS)]
    return valid.head(1) if not valid.empty else group.head(1)


# ---------------- Data prep ----------------
def normalize_columns(df: pd.DataFrame) -> pd.DataFrame:
    new_cols = []
    for c in df.columns:
        canon = c.strip().lower().replace(" ", "_")
        canon = COLUMN_ALIASES.get(canon, canon)
        new_cols.append(canon)
    df.columns = new_cols
    return df


def require_columns(df: pd.DataFrame) -> Optional[str]:
    missing = [c for c in REQUIRED_COLS if c not in df.columns]
    if missing:
        return f"Required columns not found: {', '.join(missing)}.\nFound columns: {list(df.columns)}"
    return None


def clean_and_enrich(df: pd.DataFrame) -> pd.DataFrame:
    """
    Main cleansing logic:

    - Keep all columns (we don't drop non-REQUIRED cols).
    - Drop rows missing REQUIRED_COLS.
    - If contact_num exists, drop SCA/mirrored lines entirely.
    - Build DeviceKey as contact_num (preferred) or digestusername.
    - Per DeviceKey+realm, keep only a single row, preferring non-shadow IPs.
    - Parse UA -> Device Type & Firmware Version.
    - Build normalized version tuple and Marsha Code.
    """
    # Drop rows missing required keys
    df = df.dropna(subset=REQUIRED_COLS).copy()

    # Drop Shared Call Appearance / mirrored registrations entirely
    if "contact_num" in df.columns:
        sca_mask = df["contact_num"].astype(str).str.match(SCA_SUFFIX_RE)
        df = df[~sca_mask].copy()

    # Parse UA into Device Type + Firmware Version
    df[["Device Type", "Firmware Version"]] = df["ua"].apply(
        lambda x: pd.Series(extract_device_firmware(x))
    )

    # DeviceKey = contact_num (if present), otherwise digestusername
    if "contact_num" in df.columns:
        df["DeviceKey"] = df["contact_num"].astype(str)
    else:
        df["DeviceKey"] = df["digestusername"].astype(str)

    # For each DeviceKey + realm, prefer non-shadow IPs
    df = (
        df.groupby(["DeviceKey", "digestrealm"], group_keys=False)
        .apply(prioritize_valid_ip)
        .reset_index(drop=True)
    )

    # Version normalization and Marsha derivation
    df["Firmware Version Numeric"] = df["Firmware Version"].apply(parse_version)
    df["__ver_norm__"] = df["Firmware Version Numeric"].apply(
        lambda t: _pad_tuple(t, 6)
    )
    df["Marsha Code"] = (
        df["digestrealm"].astype(str).str.split(".").str[0].str.upper()
    )
    return df


# ---------------- Analytics helpers ----------------
def _device_key_col(df: pd.DataFrame) -> str:
    """
    Internal helper: pick the right column to represent a unique phone.
    Preference: DeviceKey -> contact_num -> digestusername.
    """
    if "DeviceKey" in df.columns:
        return "DeviceKey"
    if "contact_num" in df.columns:
        return "contact_num"
    return "digestusername"


def _analytics_base(df: pd.DataFrame) -> pd.DataFrame:
    """
    Return the canonical "one phone per DeviceKey+realm" analytics base:
    - Drops shadow IPs entirely (INVALID_IPS).
    - Dedupes by DeviceKey + realm.
    """
    key_col = _device_key_col(df)
    return (
        df[~df["contact_domain"].isin(INVALID_IPS)]
        .drop_duplicates(subset=[key_col, "digestrealm"])
        .copy()
    )


def marsha_count(df: pd.DataFrame) -> pd.DataFrame:
    """
    Per-Marsha stats, including percentage of the total fleet.
    Uses DeviceKey/contact_num instead of digestusername, so
    SCA lines and shadow IP registrations are not over-counted.
    """
    use = _analytics_base(df)

    grouped = (
        use.groupby(["Marsha Code", "digestrealm"], as_index=False)
        .size()
        .rename(columns={"size": "Count"})
    )

    total = grouped["Count"].sum()
    if total > 0:
        grouped["Percent of Total (%)"] = grouped["Count"].apply(
            lambda v: f"{(v / total) * 100:.1f}%"
        )
    else:
        grouped["Percent of Total (%)"] = "0.0%"

    total_row = pd.DataFrame(
        [
            [
                "TOTAL",
                "ALL DOMAINS",
                total,
                "100.0%" if total > 0 else "0.0%",
            ]
        ],
        columns=["Marsha Code", "digestrealm", "Count", "Percent of Total (%)"],
    )

    return pd.concat([grouped, total_row], ignore_index=True)


def firmware_count(df: pd.DataFrame) -> pd.DataFrame:
    """
    Per-device-type FW stats, with 'latest', 'behind latest', and percentages.
    Uses DeviceKey/contact_num instead of digestusername.
    Only counts non-shadow registrations.
    """
    use = _analytics_base(df)

    grouped = (
        use.groupby(["Device Type", "Firmware Version"], as_index=False)
        .size()
        .rename(columns={"size": "Device Count"})
    )

    grouped["__ver_norm_fw__"] = grouped["Firmware Version"].apply(parse_version).apply(
        lambda t: _pad_tuple(t, 6)
    )

    latest = (
        grouped.sort_values(["Device Type", "__ver_norm_fw__"])
        .groupby("Device Type", as_index=False)
        .last()[["Device Type", "Firmware Version"]]
        .rename(columns={"Firmware Version": "Latest Version"})
    )

    merged = grouped.merge(latest, on="Device Type", how="left")

    merged["Latest __ver__"] = merged["Latest Version"].apply(parse_version).apply(
        lambda t: _pad_tuple(t, 6)
    )
    merged["Is Latest?"] = merged["__ver_norm_fw__"].eq(merged["Latest __ver__"])
    merged["Behind Latest?"] = merged["__ver_norm_fw__"] < merged["Latest __ver__"]

    merged["Model Total"] = merged.groupby("Device Type")["Device Count"].transform(
        "sum"
    )
    fleet_total = merged["Device Count"].sum()

    def fmt_pct(n, d):
        if not d or d == 0:
            return "0.0%"
        return f"{(n / d) * 100:.1f}%"

    merged["Model Share (%)"] = merged.apply(
        lambda r: fmt_pct(r["Device Count"], r["Model Total"]), axis=1
    )
    merged["Fleet Share (%)"] = merged.apply(
        lambda r: fmt_pct(r["Device Count"], fleet_total), axis=1
    )

    merged = merged.sort_values(
        by=["Device Type", "__ver_norm_fw__", "Device Count"],
        ascending=[True, False, False],
    )

    return merged[
        [
            "Device Type",
            "Firmware Version",
            "Device Count",
            "Latest Version",
            "Is Latest?",
            "Behind Latest?",
            "Model Share (%)",
            "Fleet Share (%)",
        ]
    ]


def fw_filter(
    df: pd.DataFrame, version_prefix: Optional[str], latest_version: Optional[str]
) -> pd.DataFrame:
    """
    Outdated/filtered FW view used by the FW Filter tab.

    Uses the same analytics base (contact_num+realm, no SCA, no shadow IPs).
    """
    use = _analytics_base(df)

    if latest_version:
        latest_tuple = _pad_tuple(parse_version(latest_version), 6)
        use = use[use["__ver_norm__"] < latest_tuple]

    if version_prefix:
        vp = version_prefix.strip()
        use = use[use["Firmware Version"].astype(str).str.startswith(vp)]

    return use[
        [
            "digestusername",
            "digestrealm",
            "Firmware Version",
            "Device Type",
            "contact_domain",
            "Marsha Code",
        ]
    ]


# ---------------- UI helpers ----------------
def make_style(root) -> ttk.Style:
    style = ttk.Style(root)
    if _HAS_TTKBOOTSTRAP:
        # ttkbootstrap will handle theme
        pass
    else:
        try:
            style.theme_use("vista" if sys.platform.startswith("win") else "clam")
        except Exception:
            style.theme_use("clam")
    style.configure("Card.TFrame", background="#f7f7fb")
    style.configure("KPI.TLabel", font=("Segoe UI", 12, "bold"))
    style.configure("Small.TLabel", font=("Segoe UI", 9))
    style.configure("Header.TLabel", font=("Segoe UI", 11, "bold"))
    style.configure("Search.TEntry", padding=4)
    style.configure("TNotebook.Tab", padding=(12, 6))
    style.configure("Treeview", rowheight=22)
    return style


def treeview_sortable(tree: ttk.Treeview):
    def sort_column(col, reverse):
        data = [(tree.set(k, col), k) for k in tree.get_children("")]
        try:
            data.sort(key=lambda t: float(str(t[0]).replace(",", "")), reverse=reverse)
        except Exception:
            data.sort(key=lambda t: str(t[0]).lower(), reverse=reverse)
        for idx, (_, k) in enumerate(data):
            tree.move(k, "", idx)
        tree.heading(col, command=lambda: sort_column(col, not reverse))

    for col in tree["columns"]:
        tree.heading(col, text=col, anchor="w", command=lambda c=col: sort_column(c, False))


def populate_tree_flat(tree: ttk.Treeview, df: pd.DataFrame):
    tree.delete(*tree.get_children())
    tree["columns"] = list(df.columns)
    tree["show"] = "headings"
    for c in df.columns:
        tree.heading(c, text=c, anchor="w")
        tree.column(c, width=140, anchor="w")
    # zebra stripes
    for i, (_, row) in enumerate(df.iterrows()):
        tag = "odd" if i % 2 else "even"
        tree.insert("", "end", values=[row[c] for c in df.columns], tags=(tag,))
    tree.tag_configure("even", background="#ffffff")
    tree.tag_configure("odd", background="#f4f6fa")
    treeview_sortable(tree)


def populate_tree_grouped_by_site(
    tree: ttk.Treeview, df: pd.DataFrame, site_order: Optional[List[str]] = None
):
    tree.delete(*tree.get_children())
    cols = ["digestusername", "digestrealm", "Firmware Version", "Device Type", "contact_domain"]
    tree["columns"] = cols
    tree["show"] = "tree headings"
    for c in cols:
        tree.heading(c, text=c, anchor="w")
        tree.column(c, width=150 if c != "digestusername" else 180, anchor="w")

    if site_order is None:
        site_order = sorted(df["Marsha Code"].dropna().unique().tolist())

    for site in site_order:
        site_rows = df[df["Marsha Code"] == site]
        if site_rows.empty:
            continue
        parent = tree.insert("", "end", text=f"{site}", open=True)
        for i, (_, row) in enumerate(site_rows.iterrows()):
            tag = "odd" if i % 2 else "even"
            values = [
                row["digestusername"],
                row["digestrealm"],
                row["Firmware Version"],
                row["Device Type"],
                row["contact_domain"],
            ]
            tree.insert(parent, "end", values=values, tags=(tag,))
    tree.tag_configure("even", background="#ffffff")
    tree.tag_configure("odd", background="#f4f6fa")


def filter_tree(
    tree: ttk.Treeview,
    df: pd.DataFrame,
    query: str,
    grouped: bool,
    site_filter: Optional[str],
):
    base = df
    if site_filter and site_filter != "All":
        base = base[base["Marsha Code"] == site_filter]
    if query:
        q = query.lower()
        mask = base.apply(lambda s: s.astype(str).str.lower().str.contains(q, na=False))
        base = base[mask.any(axis=1)]
    if grouped:
        populate_tree_grouped_by_site(tree, base)
    else:
        populate_tree_flat(tree, base)


def copy_tree_to_clipboard(root: tk.Tk, df: pd.DataFrame):
    text = df.to_csv(index=False)
    root.clipboard_clear()
    root.clipboard_append(text)
    messagebox.showinfo("Copied", "Current table copied to clipboard (CSV).")


def export_table(df: pd.DataFrame, to_excel: bool):
    ext = ".xlsx" if to_excel else ".csv"
    f = filedialog.asksaveasfilename(
        defaultextension=ext,
        filetypes=[("Excel", "*.xlsx"), ("CSV", "*.csv"), ("All files", "*.*")],
    )
    if not f:
        return
    try:
        if to_excel:
            df.to_excel(f, index=False)
        else:
            df.to_csv(f, index=False)
        messagebox.showinfo("Exported", f"Saved: {f}")
    except Exception as e:
        messagebox.showerror("Export failed", str(e))


def save_current_figure():
    f = filedialog.asksaveasfilename(
        defaultextension=".png",
        filetypes=[("PNG Image", "*.png"), ("All files", "*.*")],
    )
    if not f:
        return
    try:
        plt.gcf().savefig(f, dpi=160, bbox_inches="tight")
        messagebox.showinfo("Saved", f"Chart saved to: {f}")
    except Exception as e:
        messagebox.showerror("Save failed", str(e))


